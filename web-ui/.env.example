# Prisma/PostgreSQL connection string
# Default docker-compose credentials:
#   user: cad_user
#   password: cad_pass
#   db: cad_db
DATABASE_URL=postgresql://cad_user:cad_pass@localhost:5432/cad_db?schema=public

# Server-side BFF proxy target (Next.js API routes -> FastAPI)
FASTAPI_URL=http://127.0.0.1:8000/api/v1

# Client-side URL for model/artifact loading in browser
NEXT_PUBLIC_FASTAPI_URL=http://127.0.0.1:8000/api/v1
