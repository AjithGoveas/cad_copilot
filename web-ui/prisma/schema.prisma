generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CadSession {
  id           String   @id @default(cuid())
  prompt       String
  pythonScript String?
  parameters   Json?
  stlUrl       String?
  stepUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
